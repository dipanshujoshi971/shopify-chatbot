# ─────────────────────────────────────────────
# ShopChat — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
NODE_ENV=development

# ── Database (shared by API + Dashboard) ─────
DATABASE_URL=postgresql://postgres:password@localhost:5432/shopchat

# ── API Server (apps/api) ────────────────────
PORT=3001
HOST=0.0.0.0
APP_URL=http://localhost:3001

# Valkey / Redis — used for caching, rate limits, session state
VALKEY_URL=redis://localhost:6379

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# ── Shopify OAuth ────────────────────────────
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_script_tags,read_customers,write_webhooks

# ── LLM Provider ─────────────────────────────
# Options: anthropic (default), openai
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic (read automatically by @ai-sdk/anthropic)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Required only when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-your_openai_api_key

# ── Dashboard (apps/dashboard) ───────────────
# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Public API URL — used for widget embed code generation
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Email (Ticket Reply Notifications) ───────
# Uses Resend (https://resend.com) — sign up for a free API key
# Without this, ticket replies won't be emailed to customers
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=support@yourdomain.com

# ── Stripe (Billing) ─────────────────────────
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
