# ─────────────────────────────────────────────
# App — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
NODE_ENV=development

# App display name — shown across the dashboard UI
NEXT_PUBLIC_APP_NAME=ShopChat

# ── Database (shared by API + Dashboard) ─────
DATABASE_URL=postgresql://postgres:password@localhost:5432/shopchat

# ── API Server (apps/api) ────────────────────
PORT=3001
HOST=0.0.0.0
APP_URL=http://localhost:3001

# Valkey / Redis — used for caching, rate limits, session state
VALKEY_URL=redis://localhost:6379

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# Shared HMAC secret for signing short-lived realtime (socket.io) tickets
# the dashboard mints for authenticated merchants. Must be identical on
# the API and dashboard. Generate with: openssl rand -hex 32
INTERNAL_HMAC_SECRET=replace_with_32_bytes_hex_or_base64

# ── Shopify OAuth ────────────────────────────
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_customers,write_webhooks

# ── OpenAI (used for both LLM and embeddings) ─
OPENAI_API_KEY=sk-proj-your_openai_api_key

# ── Cloudflare R2 (file storage) ─────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name

# ── Dashboard (apps/dashboard) ───────────────
# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Public API URL — used for widget embed code generation
NEXT_PUBLIC_API_URL=http://localhost:3001

# Super Admin — comma-separated Clerk user IDs that can access /admin
# Find your Clerk user ID in the Clerk dashboard under Users
SUPER_ADMIN_CLERK_IDS=

# ── Email (Ticket Reply Notifications) ───────
# Uses Resend (https://resend.com) — sign up for a free API key
# Without this, ticket replies won't be emailed to customers
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=support@yourdomain.com
