{% comment %}
  Manual Embed Snippet — ShopChat AI Chatbot

  For merchants who prefer manual installation over the app embed block,
  add this snippet to theme.liquid before </body>:

    {% render 'shopbot-embed', api_key: 'pk_xxx', api_url: 'https://api.yourapp.com' %}

  The shop domain is auto-detected from the Shopify store.
{% endcomment %}

{% if api_key != blank %}
  <script
    src="{{ widget_url | default: 'https://api.shopbot.ai/widget.iife.js' }}"
    data-api-key="{{ api_key }}"
    data-shop-domain="{{ shop.permanent_domain }}"
    data-title="{{ shop.name }}"
    data-position="{{ position | default: 'right' }}"
    {% if api_url != blank %}
      data-api-url="{{ api_url }}"
    {% endif %}
    {% if accent_color != blank %}
      data-accent-color="{{ accent_color }}"
    {% endif %}
    async
    defer
  ></script>
{% endif %}
